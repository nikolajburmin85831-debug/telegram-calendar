# =========================================================
# .env.example
# Assistant Core - EC2-first, Lambda-ready
# =========================================================
# Copy this file to `.env` (or use environment variables directly)
# and fill in real values only in your local/private environment.
#
# IMPORTANT:
# - Never commit real secrets.
# - Keep this file as documentation / template only.
# - `local` keeps stub/in-memory behavior.
# - `smoke` enables real Telegram + Gemini + Google Calendar + durable persistence.
# - These variable names are canonical for every runtime:
#   local `.env`, OS environment variables, Docker/Kubernetes secrets,
#   or secret files mounted into `./secrets`, `../secrets`, `/run/secrets`, `/etc/secrets`.
# =========================================================

# =========================================================
# 1) Runtime mode
# =========================================================
SPRING_PROFILES_ACTIVE=local
APP_ENV=local
APP_DEFAULT_TIMEZONE=Europe/Moscow
APP_DEFAULT_LANGUAGE=ru

# =========================================================
# 2) Feature / adapter mode switches
# =========================================================
APP_TELEGRAM_MODE=stub
APP_GEMINI_MODE=stub
APP_GOOGLE_CALENDAR_MODE=stub
APP_PERSISTENCE_MODE=inmemory
APP_AUDIT_MODE=inmemory

# =========================================================
# 3) Telegram Bot API
# =========================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_BASE_URL=https://api.telegram.org
TELEGRAM_POLLING_ENABLED=true
TELEGRAM_NOTIFICATION_ENABLED=true
TELEGRAM_POLLING_TIMEOUT_SECONDS=20
TELEGRAM_POLLING_LIMIT=100
TELEGRAM_POLLING_FIXED_DELAY_MS=1500
TELEGRAM_STUB_USER_ID=10001
TELEGRAM_STUB_CHAT_ID=20001

# =========================================================
# HTTP client / proxy
# =========================================================
# Use Windows/macOS system proxy settings when available.
HTTP_USE_SYSTEM_PROXY=false
# Optional explicit proxy. If set together with HTTP_PROXY_ENABLED=true,
# it takes precedence over system proxy detection.
HTTP_PROXY_ENABLED=false
HTTP_PROXY_URL=
HTTP_PROXY_USERNAME=
HTTP_PROXY_PASSWORD=

# =========================================================
# 4) Gemini / Google AI
# =========================================================
GEMINI_API_KEY=
# Optional override. Leave empty to use assistant.gemini.model from application.yml.
GEMINI_MODEL=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_FALLBACK_TO_STUB_ON_ERROR=true

# =========================================================
# 5) Google Calendar / OAuth
# =========================================================
GOOGLE_CALENDAR_BASE_URL=https://www.googleapis.com/calendar/v3
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_DEFAULT_TIMEZONE=Europe/Moscow
GOOGLE_CALENDAR_REAL_ENABLED=false

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_OAUTH_ACCESS_TOKEN=
GOOGLE_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/calendar
GOOGLE_OAUTH_CREDENTIAL_SOURCE=env

# =========================================================
# 6) Durable persistence
# =========================================================
# Example for PostgreSQL-backed durable storage used by smoke mode.
DB_URL=jdbc:postgresql://localhost:5432/assistant
DB_USERNAME=assistant
DB_PASSWORD=assistant
DB_DRIVER=org.postgresql.Driver
DB_SCHEMA=public
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2
DB_POOL_CONNECTION_TIMEOUT_MS=30000

# =========================================================
# 7) App behavior / safety
# =========================================================
APP_REQUIRE_CONFIRMATION=false
APP_DEFAULT_REMINDER_DURATION_MINUTES=15
APP_DEFAULT_MEETING_DURATION_MINUTES=30
APP_IDEMPOTENCY_TTL_HOURS=24

# =========================================================
# 8) Logging / diagnostics
# =========================================================
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG

# =========================================================
# 9) Household notifications
# =========================================================
HOUSEHOLD_NOTIFICATIONS_ENABLED=false
HOUSEHOLD_ME_DISPLAY_NAME=Я
HOUSEHOLD_ME_TELEGRAM_USER_ID=
HOUSEHOLD_ME_CHAT_IDS=
HOUSEHOLD_ME_NOTIFY_MEMBERS=
HOUSEHOLD_WIFE_DISPLAY_NAME=Жена
HOUSEHOLD_WIFE_TELEGRAM_USER_ID=
HOUSEHOLD_WIFE_CHAT_IDS=
HOUSEHOLD_WIFE_NOTIFY_MEMBERS=me

# =========================================================
# 10) Suggested real smoke combination
# =========================================================
# SPRING_PROFILES_ACTIVE=smoke
# APP_TELEGRAM_MODE=real
# APP_GEMINI_MODE=real
# APP_GOOGLE_CALENDAR_MODE=real
# APP_PERSISTENCE_MODE=jdbc
# APP_AUDIT_MODE=jdbc
# GOOGLE_CALENDAR_REAL_ENABLED=true
#
# Plus real values for:
# - TELEGRAM_BOT_TOKEN
# - GEMINI_API_KEY
# - GOOGLE_OAUTH_CLIENT_ID
# - GOOGLE_OAUTH_CLIENT_SECRET
# - GOOGLE_OAUTH_REFRESH_TOKEN
# - DB_URL / DB_USERNAME / DB_PASSWORD
